set scrolloff=10
set incsearch
set hlsearch
set ignorecase
set smartcase
set ideajoin
set idearefactormode=keep

let mapleader=" "

nnoremap Y y$
nnoremap <leader><space> :nohlsearch<CR>

nnoremap <leader>e <Action>(SelectInProjectView)
nnoremap <leader>p <Action>(SearchEverywhere)
nnoremap <leader>f <Action>(GotoFile)

nnoremap gd <Action>(GotoDeclaration)
nnoremap gi <Action>(GotoImplementation)
nnoremap gr <Action>(FindUsages)

nnoremap <leader>rn <Action>(RenameElement)
nnoremap <leader>cf <Action>(ReformatCode)
nnoremap <leader>co <Action>(OptimizeImports)
nnoremap <leader>a <Action>(ShowIntentionActions)

nnoremap <leader>gl :action Vcs.Show.Log<CR>
nnoremap <leader>rb <Action>(ToggleLineBreakpoint)
nnoremap <leader>4 <Action>(ActivateTerminalToolWindow)
